<odoo>
    <data>
            <record id="server_action_uom_auto" model="ir.actions.server">
        <field name="name">Set UoM to Ref</field>
        <field name="model_id" ref="product.model_product_template"/>
        <field name="state">code</field>
        <field name="code">
                    record._assign_default_code()
        </field>
    </record>
        <record id="action_uom_auto" model="base.automation">
            <field name="name">Set UoM to Ref</field>
            <field name="trigger">on_create_or_write</field>
            <field name="model_id" ref="product.model_product_template"/>
            <field name="trigger_field_ids" search="[('name', '=', 'uom_id'),('model_id', '=', ref('product.model_product_template'))]"/>
            <field name="action_server_ids"  eval="[(4, ref('server_action_uom_auto'))]"/>
        </record>
    </data>
</odoo>