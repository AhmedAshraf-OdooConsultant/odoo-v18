<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inherit Form View -->
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.module</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="sale.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <!-- Add fields to an existing group -->
            <xpath expr="//app[@name='sale_management']/block[@name='catalog_setting_container']" position="inside">
                <setting string="Set UOM to Ref" help="Enable the automated action to set UOM to reference in the product" id="product_uom_auto_action">
                            <field name="set_uom_to_reference"/>
                        </setting>
            </xpath>

        </field>
    </record>

</odoo>