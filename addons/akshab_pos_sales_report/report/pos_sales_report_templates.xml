<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_pos_sales_doc">
        <t t-call="web.html_container">
            <t t-call="web.basic_layout">
                <div class="page" dir="rtl">
                    <style>
                        @font-face {
                            font-family: 'Tajawal';
                            src: url('/akshab_pos_sales_report/static/fonts/Tajawal-Regular.ttf') format('truetype');
                            font-weight: normal;
                            font-style: normal;
                        }
                        @font-face {
                            font-family: 'Tajawal';
                            src: url('/akshab_pos_sales_report/static/fonts/Tajawal-Medium.ttf') format('truetype');
                            font-weight: 500;
                            font-style: normal;
                        }
                        @font-face {
                            font-family: 'Tajawal';
                            src: url('/akshab_pos_sales_report/static/fonts/Tajawal-Bold.ttf') format('truetype');
                            font-weight: bold;
                            font-style: normal;
                        }
                        .akshab-report {
                            direction: rtl;
                            text-align: right;
                            font-family: 'Tajawal', 'Noto Naskh Arabic', 'DejaVu Sans', sans-serif;
                            color: #26312B;
                            font-size: 15px;
                        }
                        .akshab-report table { direction: rtl; }
                        /* ---------- الترويسة (divs عائمة - بدون جدول = استحالة ظهور خطوط) ---------- */
                        .ak-header { width: 100%; overflow: hidden; margin-bottom: 16px; }
                        .ak-header-titles { float: right; text-align: right; }
                        .ak-header-logo { float: left; text-align: left; }
                        .ak-logo { max-height: 76px; max-width: 230px; }
                        .ak-title { font-size: 32px; font-weight: bold; color: #1B4332; margin: 0; line-height: 1.25; border: 0 !important; }
                        .ak-subtitle { font-size: 15px; color: #C6A46C; font-weight: bold; margin: 3px 0 0 0; letter-spacing: 3px; border: 0 !important; }
                        /* ---------- مؤشرات الأداء ---------- */
                        .akshab-report .ak-kpi-table { width: 100%; border-collapse: separate; border-spacing: 5px 0; margin: 4px 0 14px 0; border: 0 !important; }
                        .akshab-report .ak-kpi-table td {
                            background-color: #F7F4EE;
                            border: 0 !important;
                            border-top: 3px solid #C6A46C !important;
                            border-bottom: 1px solid #E5DECF !important;
                            padding: 11px 6px 9px 6px;
                            text-align: center;
                            width: 14.28%;
                        }
                        .ak-kpi-value { font-size: 19px; font-weight: bold; color: #1B4332; direction: ltr; unicode-bidi: embed; white-space: nowrap; }
                        .ak-kpi-value-rtl { font-size: 19px; font-weight: bold; color: #1B4332; direction: rtl; white-space: nowrap; }
                        .ak-kpi-label { font-size: 12.5px; color: #7A6A45; font-weight: 500; margin-top: 3px; }
                        /* ---------- صندوق معلومات الفترة ---------- */
                        .akshab-report .ak-info-box { width: 100%; border-collapse: collapse; margin-bottom: 20px; background-color: #FDFCF9; }
                        .akshab-report .ak-info-box td { padding: 9px 15px; font-size: 14.5px; border: 1px solid #E5DECF !important; }
                        .akshab-report .ak-info-box td.ak-info-label { color: #1B4332; font-weight: bold; white-space: nowrap; width: 1%; background-color: #EFE9DC; }
                        /* ---------- منع انفصال العنوان عن محتواه بين الصفحات ---------- */
                        .ak-keep { page-break-inside: avoid; }
                        .ak-page-start { page-break-before: always; }
                        .ak-section-block { margin-top: 26px; }
                        /* ---------- عناوين الأقسام ---------- */
                        .ak-section-title {
                            background-color: #1B4332; color: #FFFFFF;
                            font-size: 18.5px; font-weight: bold;
                            padding: 10px 17px; margin: 26px 0 0 0;
                            border-right: 6px solid #C6A46C;
                            page-break-after: avoid;
                        }
                        .akshab-report .ak-table caption.ak-section-caption {
                            caption-side: top;
                            background-color: #1B4332; color: #FFFFFF;
                            font-size: 18.5px; font-weight: bold;
                            padding: 10px 17px; text-align: right;
                            border-right: 6px solid #C6A46C;
                            margin: 0;
                        }
                        .ak-table thead tr { page-break-inside: avoid; }
                        .akshab-report .ak-section-table { margin-top: 26px; }
                        .ak-section-num {
                            display: inline-block; color: #C6A46C; font-weight: bold; margin-left: 10px;
                        }
                        /* ---------- الجداول ---------- */
                        .akshab-report .ak-table { width: 100%; border-collapse: collapse; margin-top: 0; }
                        .akshab-report .ak-table th {
                            background-color: #1B4332; color: #FFFFFF;
                            padding: 10px 8px; font-size: 15px; font-weight: bold;
                            border: 1px solid #143226 !important; text-align: center;
                        }
                        .akshab-report .ak-table td {
                            padding: 8px 8px; font-size: 14.5px;
                            border: 1px solid #DDD6C7 !important; text-align: center;
                        }
                        .akshab-report .ak-table td.ak-right { text-align: right; }
                        .akshab-report .ak-table tr:nth-child(even) td { background-color: #F7F4EE; }
                        .ak-table tr { page-break-inside: avoid; }
                        .ak-table thead { display: table-header-group; page-break-inside: avoid; }
                        .akshab-report .ak-total-row td {
                            background-color: #EAE0CC !important; color: #1B4332;
                            font-weight: bold; font-size: 14.5px;
                            border-top: 2px solid #C6A46C !important;
                        }
                        .akshab-report .ak-subtotal-row td {
                            background-color: #F0E9DA !important; color: #1B4332;
                            font-weight: bold; font-size: 14px;
                        }
                        .akshab-report .ak-cat-row td {
                            background-color: #2D5443 !important; color: #FFFFFF;
                            font-weight: bold; text-align: right; font-size: 14.5px;
                        }
                        .akshab-report .ak-cat-row td.ak-num { text-align: center; }
                        .ak-pos-band {
                            background-color: #C6A46C; color: #1B4332;
                            font-weight: bold; font-size: 16px;
                            padding: 8px 15px; margin: 18px 0 0 0;
                            page-break-after: avoid;
                        }
                        .ak-empty { color: #8A8A8A; font-size: 14px; padding: 12px 6px; font-style: italic; }
                        .ak-amount { direction: ltr; unicode-bidi: embed; white-space: nowrap; }
                        .ak-badge-new { color: #1B4332; font-weight: bold; }
                        .ak-badge-old { color: #7A6A45; font-weight: bold; }
                    </style>

                    <div class="akshab-report">
                        <!-- ==================== الترويسة ==================== -->
                        <div class="ak-header">
                            <div class="ak-header-titles">
                                <p class="ak-title">تقرير مبيعات التجزئة</p>
                                <p class="ak-subtitle">RETAIL SALES REPORT</p>
                            </div>
                            <div class="ak-header-logo">
                                <img t-if="company.logo" class="ak-logo"
                                     t-att-src="image_data_uri(company.logo)"/>
                                <p t-else="" class="ak-title" t-out="data.get('company_name')"/>
                            </div>
                        </div>

                        <!-- ==================== مؤشرات الأداء التنفيذية ==================== -->
                        <table t-if="data.get('has_data')" class="ak-kpi-table">
                            <tr>
                                <td>
                                    <div class="ak-kpi-value" t-out="data['kpis']['gross_fmt']"/>
                                    <div class="ak-kpi-label">إجمالي المبيعات (ر.س)</div>
                                </td>
                                <td>
                                    <div class="ak-kpi-value" t-out="data['kpis']['refunds_fmt']"/>
                                    <div class="ak-kpi-label">المرتجعات (ر.س)</div>
                                </td>
                                <td>
                                    <div class="ak-kpi-value" t-out="data['kpis']['net_fmt']"/>
                                    <div class="ak-kpi-label">صافي المبيعات (ر.س)</div>
                                </td>
                                <td>
                                    <div class="ak-kpi-value" t-out="data['kpis']['invoices']"/>
                                    <div class="ak-kpi-label">عدد الفواتير</div>
                                </td>
                                <td>
                                    <div class="ak-kpi-value" t-out="data['kpis']['avg_fmt']"/>
                                    <div class="ak-kpi-label">متوسط الفاتورة (ر.س)</div>
                                </td>
                                <td>
                                    <div class="ak-kpi-value" t-out="data['kpis']['discounts_fmt']"/>
                                    <div class="ak-kpi-label">إجمالي الخصومات (ر.س)</div>
                                </td>
                                <td>
                                    <div class="ak-kpi-value-rtl">&#8207;<t t-out="data['kpis']['customers_display']"/></div>
                                    <div class="ak-kpi-label">عدد العملاء</div>
                                </td>
                            </tr>
                        </table>

                        <table class="ak-info-box">
                            <tr t-if="data.get('show_day')">
                                <td class="ak-info-label">اليوم</td>
                                <td colspan="3" t-out="data.get('day_name')"/>
                            </tr>
                            <tr>
                                <td class="ak-info-label">الفترة من</td>
                                <td><span class="ak-amount" t-out="data.get('date_from')"/></td>
                                <td class="ak-info-label">إلى</td>
                                <td><span class="ak-amount" t-out="data.get('date_to')"/></td>
                            </tr>
                            <tr>
                                <td class="ak-info-label">الفروع</td>
                                <td colspan="3" t-out="data.get('config_names')"/>
                            </tr>
                            <tr>
                                <td class="ak-info-label">تاريخ الطباعة</td>
                                <td><span class="ak-amount" t-out="data.get('printed_on')"/></td>
                                <td class="ak-info-label">العملة</td>
                                <td>ريال سعودي (<t t-out="data.get('currency')"/>)</td>
                            </tr>
                        </table>

                        <t t-if="not data.get('has_data')">
                            <p class="ak-empty">لا توجد عمليات بيع ضمن الفترة والفروع المحددة.</p>
                        </t>

                        <t t-if="data.get('has_data')">
                        <!-- ==================== القسم 1: إجمالي المبيعات ==================== -->
                        <div class="ak-keep">
                        <div class="ak-section-title"><span class="ak-section-num">١</span> إجمالي المبيعات حسب الفرع</div>
                        <table class="ak-table">
                            <thead>
                                <tr>
                                    <th style="width: 17%;">الفرع</th>
                                    <th style="width: 13%;">صافي المبيعات (<t t-out="data['currency']"/>)</th>
                                    <th style="width: 8%;">النسبة</th>
                                    <th style="width: 10%;">عدد الفواتير</th>
                                    <th style="width: 11%;">متوسط الفاتورة</th>
                                    <th style="width: 13%;">إجمالي الخصومات (<t t-out="data['currency']"/>)</th>
                                    <th style="width: 10%;">عدد العملاء</th>
                                    <th style="width: 9%;">عملاء جدد</th>
                                    <th style="width: 9%;">عملاء قدامى</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="data['section1']['rows']" t-as="row">
                                    <td class="ak-right" t-out="row['name']"/>
                                    <td><span class="ak-amount" t-out="row['total_fmt']"/></td>
                                    <td><span class="ak-amount" t-out="row['share_fmt']"/></td>
                                    <td t-out="row['count']"/>
                                    <td><span class="ak-amount" t-out="row['avg_fmt']"/></td>
                                    <td><span class="ak-amount" t-out="row['discounts_fmt']"/></td>
                                    <td t-out="row['customers']"/>
                                    <td class="ak-badge-new" t-out="row['new']"/>
                                    <td class="ak-badge-old" t-out="row['old']"/>
                                </tr>
                                <tr class="ak-total-row">
                                    <td class="ak-right">الإجمالي</td>
                                    <td><span class="ak-amount" t-out="data['section1']['total']['total_fmt']"/></td>
                                    <td><span class="ak-amount" t-out="data['section1']['total']['share_fmt']"/></td>
                                    <td t-out="data['section1']['total']['count']"/>
                                    <td><span class="ak-amount" t-out="data['section1']['total']['avg_fmt']"/></td>
                                    <td><span class="ak-amount" t-out="data['section1']['total']['discounts_fmt']"/></td>
                                    <td t-out="data['section1']['total']['customers']"/>
                                    <td t-out="data['section1']['total']['new']"/>
                                    <td t-out="data['section1']['total']['old']"/>
                                </tr>
                            </tbody>
                        </table>
                        </div>

                        <!-- ==================== القسم 2: فواتير المبيعات ==================== -->
                        <t t-if="not data['section2']['rows']">
                            <div class="ak-keep">
                                <div class="ak-section-title"><span class="ak-section-num">٢</span> فواتير المبيعات</div>
                                <p class="ak-empty">لا توجد فواتير مبيعات ضمن الفترة المحددة.</p>
                            </div>
                        </t>
                        <div t-if="data['section2']['rows']" t-att-class="('ak-keep' if data['section2']['count'] &lt;= 10 else 'ak-page-start') + ' ak-section-block'">
                        <table class="ak-table">
                            <caption class="ak-section-caption"><span class="ak-section-num">٢</span> فواتير المبيعات</caption>
                            <thead>
                                <tr>
                                    <th style="width: 11%;">التاريخ</th>
                                    <th style="width: 12%;">رقم الفاتورة</th>
                                    <th style="width: 10%;">الفرع</th>
                                    <th style="width: 13%;">العميل</th>
                                    <th style="width: 11%;">رقم الهاتف</th>
                                    <th style="width: 8%;">عميل جديد؟</th>
                                    <th style="width: 11%;">تاريخ آخر فاتورة</th>
                                    <th style="width: 10%;">الأيام منذ آخر فاتورة</th>
                                    <th style="width: 14%;">الإجمالي (<t t-out="data['currency']"/>)</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="data['section2']['rows']" t-as="row">
                                    <td><span class="ak-amount" t-out="row['date']"/></td>
                                    <td><span class="ak-amount" t-out="row['number']"/></td>
                                    <td t-out="row['pos']"/>
                                    <td t-out="row['customer']"/>
                                    <td><span class="ak-amount" t-out="row['phone']"/></td>
                                    <td t-out="row['is_new']"/>
                                    <td><span class="ak-amount" t-out="row['last_inv']"/></td>
                                    <td t-out="row['days']"/>
                                    <td><span class="ak-amount" t-out="row['total_fmt']"/></td>
                                </tr>
                                <tr class="ak-total-row">
                                    <td class="ak-right" colspan="2">الإجمالي</td>
                                    <td colspan="6">عدد الفواتير: <t t-out="data['section2']['count']"/></td>
                                    <td><span class="ak-amount" t-out="data['section2']['total_fmt']"/></td>
                                </tr>
                            </tbody>
                        </table>
                        </div>

                        <!-- ==================== القسم 3: مرتجعات المبيعات ==================== -->
                        <t t-if="not data['section3']['rows']">
                            <div class="ak-keep">
                                <div class="ak-section-title"><span class="ak-section-num">٣</span> فواتير مرتجعات المبيعات</div>
                                <p class="ak-empty">لا توجد مرتجعات مبيعات ضمن الفترة المحددة.</p>
                            </div>
                        </t>
                        <div t-if="data['section3']['rows']" t-att-class="('ak-keep' if data['section3']['count'] &lt;= 10 else 'ak-page-start') + ' ak-section-block'">
                        <table class="ak-table">
                            <caption class="ak-section-caption"><span class="ak-section-num">٣</span> فواتير مرتجعات المبيعات</caption>
                            <thead>
                                <tr>
                                    <th style="width: 13%;">التاريخ</th>
                                    <th style="width: 14%;">رقم الفاتورة</th>
                                    <th style="width: 12%;">الفرع</th>
                                    <th style="width: 17%;">العميل</th>
                                    <th style="width: 13%;">رقم الهاتف</th>
                                    <th style="width: 13%;">تاريخ آخر فاتورة</th>
                                    <th style="width: 18%;">الإجمالي (<t t-out="data['currency']"/>)</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="data['section3']['rows']" t-as="row">
                                    <td><span class="ak-amount" t-out="row['date']"/></td>
                                    <td><span class="ak-amount" t-out="row['number']"/></td>
                                    <td t-out="row['pos']"/>
                                    <td t-out="row['customer']"/>
                                    <td><span class="ak-amount" t-out="row['phone']"/></td>
                                    <td><span class="ak-amount" t-out="row['last_inv']"/></td>
                                    <td><span class="ak-amount" t-out="row['total_fmt']"/></td>
                                </tr>
                                <tr class="ak-total-row">
                                    <td class="ak-right" colspan="2">الإجمالي</td>
                                    <td colspan="4">عدد المرتجعات: <t t-out="data['section3']['count']"/></td>
                                    <td><span class="ak-amount" t-out="data['section3']['total_fmt']"/></td>
                                </tr>
                            </tbody>
                        </table>
                        </div>

                        <!-- ==================== القسم 4: مبيعات المنتجات ==================== -->
                        <t t-if="not data['section4']['categories']">
                            <div class="ak-keep">
                                <div class="ak-section-title"><span class="ak-section-num">٤</span> مبيعات المنتجات حسب الفئة</div>
                                <p class="ak-empty">لا توجد مبيعات منتجات ضمن الفترة المحددة.</p>
                            </div>
                        </t>
                        <t t-foreach="data['section4']['categories']" t-as="cat">
                            <div t-att-class="'ak-keep' if cat['product_count'] &lt;= 15 else 'ak-page-start'">
                            <div t-if="cat_first" class="ak-section-title"><span class="ak-section-num">٤</span> مبيعات المنتجات حسب الفئة</div>
                            <table class="ak-table">
                                <thead>
                                    <tr t-if="cat_first">
                                        <th style="width: 40%;">الفئة / المنتج</th>
                                        <th style="width: 13%;">الكمية المباعة</th>
                                        <th style="width: 15%;">متوسط سعر الوحدة (<t t-out="data['currency']"/>)</th>
                                        <th style="width: 14%;">إجمالي الخصم (<t t-out="data['currency']"/>)</th>
                                        <th style="width: 18%;">الإجمالي (<t t-out="data['currency']"/>)</th>
                                    </tr>
                                    <tr class="ak-cat-row">
                                        <td style="width: 40%;" t-out="cat['name']"/>
                                        <td style="width: 13%;" class="ak-num"><span class="ak-amount" t-out="cat['qty_fmt']"/></td>
                                        <td style="width: 15%;" class="ak-num"><span class="ak-amount" t-out="cat['avg_fmt']"/></td>
                                        <td style="width: 14%;" class="ak-num"><span class="ak-amount" t-out="cat['discount_fmt']"/></td>
                                        <td style="width: 18%;" class="ak-num"><span class="ak-amount" t-out="cat['total_fmt']"/></td>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr t-foreach="cat['products']" t-as="prod">
                                        <td class="ak-right" style="padding-right: 28px;" t-out="prod['name']"/>
                                        <td><span class="ak-amount" t-out="prod['qty_fmt']"/></td>
                                        <td><span class="ak-amount" t-out="prod['avg_fmt']"/></td>
                                        <td><span class="ak-amount" t-out="prod['discount_fmt']"/></td>
                                        <td><span class="ak-amount" t-out="prod['total_fmt']"/></td>
                                    </tr>
                                </tbody>
                            </table>
                            </div>
                        </t>
                        <div t-if="data['section4']['categories']" class="ak-keep">
                        <table class="ak-table">
                            <tbody>
                                <tr class="ak-total-row">
                                    <td style="width: 40%;" class="ak-right">الإجمالي</td>
                                    <td style="width: 13%;"><span class="ak-amount" t-out="data['section4']['total_qty_fmt']"/></td>
                                    <td style="width: 15%;"><span class="ak-amount" t-out="data['section4']['total_avg_fmt']"/></td>
                                    <td style="width: 14%;"><span class="ak-amount" t-out="data['section4']['total_discount_fmt']"/></td>
                                    <td style="width: 18%;"><span class="ak-amount" t-out="data['section4']['total_fmt']"/></td>
                                </tr>
                            </tbody>
                        </table>
                        </div>

                        <!-- ==================== القسم 5: مبيعات الموظفين ==================== -->
                        <t t-if="not data['section5']['configs']">
                            <div class="ak-keep">
                                <div class="ak-section-title"><span class="ak-section-num">٥</span> مبيعات الموظفين حسب الفرع</div>
                                <p class="ak-empty">لا توجد بيانات موظفين ضمن الفترة المحددة.</p>
                            </div>
                        </t>
                        <t t-foreach="data['section5']['configs']" t-as="cfg">
                            <div class="ak-keep">
                            <div t-if="cfg_first" class="ak-section-title"><span class="ak-section-num">٥</span> مبيعات الموظفين حسب الفرع</div>
                            <div class="ak-pos-band" t-out="cfg['name']"/>
                            <table class="ak-table">
                                <thead>
                                    <tr>
                                        <th style="width: 20%;">الموظف</th>
                                        <th style="width: 14%;">صافي المبيعات (<t t-out="data['currency']"/>)</th>
                                        <th style="width: 10%;">عدد الفواتير</th>
                                        <th style="width: 12%;">متوسط الفاتورة</th>
                                        <th style="width: 12%;">الخصومات (<t t-out="data['currency']"/>)</th>
                                        <th style="width: 12%;">عدد العملاء</th>
                                        <th style="width: 10%;">عملاء جدد</th>
                                        <th style="width: 10%;">عملاء قدامى</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr t-foreach="cfg['rows']" t-as="row">
                                        <td class="ak-right" t-out="row['name']"/>
                                        <td><span class="ak-amount" t-out="row['total_fmt']"/></td>
                                        <td t-out="row['count']"/>
                                        <td><span class="ak-amount" t-out="row['avg_fmt']"/></td>
                                        <td><span class="ak-amount" t-out="row['discounts_fmt']"/></td>
                                        <td t-out="row['customers']"/>
                                        <td class="ak-badge-new" t-out="row['new']"/>
                                        <td class="ak-badge-old" t-out="row['old']"/>
                                    </tr>
                                    <tr class="ak-total-row">
                                        <td class="ak-right">الإجمالي</td>
                                        <td><span class="ak-amount" t-out="cfg['subtotal']['total_fmt']"/></td>
                                        <td t-out="cfg['subtotal']['count']"/>
                                        <td><span class="ak-amount" t-out="cfg['subtotal']['avg_fmt']"/></td>
                                        <td><span class="ak-amount" t-out="cfg['subtotal']['discounts_fmt']"/></td>
                                        <td t-out="cfg['subtotal']['customers']"/>
                                        <td t-out="cfg['subtotal']['new']"/>
                                        <td t-out="cfg['subtotal']['old']"/>
                                    </tr>
                                </tbody>
                            </table>
                            </div>
                        </t>

                        <!-- ==================== القسم 6: تحليل الخصومات ==================== -->
                        <t t-if="not data['section6']['configs']">
                            <div class="ak-keep">
                                <div class="ak-section-title"><span class="ak-section-num">٦</span> تحليل الخصومات حسب الفرع</div>
                                <p class="ak-empty">لا توجد خصومات ضمن الفترة المحددة.</p>
                            </div>
                        </t>
                        <t t-foreach="data['section6']['configs']" t-as="cfg">
                            <div class="ak-keep">
                            <div t-if="cfg_first" class="ak-section-title"><span class="ak-section-num">٦</span> تحليل الخصومات حسب الفرع</div>
                            <div class="ak-pos-band" t-out="cfg['name']"/>
                            <table class="ak-table">
                                <thead>
                                    <tr>
                                        <th style="width: 40%;">الخصم</th>
                                        <th style="width: 22%;">إجمالي الخصم (<t t-out="data['currency']"/>)</th>
                                        <th style="width: 18%;">عدد الفواتير</th>
                                        <th style="width: 20%;">متوسط خصم الفاتورة (<t t-out="data['currency']"/>)</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr t-foreach="cfg['rows']" t-as="row">
                                        <td class="ak-right" t-out="row['name']"/>
                                        <td><span class="ak-amount" t-out="row['total_fmt']"/></td>
                                        <td t-out="row['count']"/>
                                        <td><span class="ak-amount" t-out="row['avg_fmt']"/></td>
                                    </tr>
                                    <tr class="ak-subtotal-row">
                                        <td class="ak-right">إجمالي خصومات <t t-out="cfg['name']"/></td>
                                        <td><span class="ak-amount" t-out="cfg['subtotal_fmt']"/></td>
                                        <td t-out="cfg['subtotal_count']"/>
                                        <td><span class="ak-amount" t-out="cfg['subtotal_avg_fmt']"/></td>
                                    </tr>
                                </tbody>
                            </table>
                            </div>
                        </t>
                        <div t-if="data['section6']['configs']" class="ak-keep">
                        <table class="ak-table" style="margin-top: 6px;">
                            <tbody>
                                <tr class="ak-total-row">
                                    <td class="ak-right" style="width: 40%;">الإجمالي العام للخصومات</td>
                                    <td style="width: 22%;"><span class="ak-amount" t-out="data['section6']['total_fmt']"/></td>
                                    <td style="width: 18%;" t-out="data['section6']['total_count']"/>
                                    <td style="width: 20%;"><span class="ak-amount" t-out="data['section6']['total_avg_fmt']"/></td>
                                </tr>
                            </tbody>
                        </table>
                        </div>
                        </t>
                    </div>
                </div>
            </t>
        </t>
    </template>
</odoo>
