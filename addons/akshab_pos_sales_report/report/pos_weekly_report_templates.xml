<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_pos_weekly_doc">
        <t t-call="web.html_container">
            <t t-call="web.basic_layout">
                <div class="page" dir="rtl">
                    <style>
                        @font-face {
                            font-family: 'Tajawal';
                            src: url('/akshab_pos_sales_report/static/fonts/Tajawal-Regular.ttf') format('truetype');
                            font-weight: normal;
                            font-style: normal;
                        }
                        @font-face {
                            font-family: 'Tajawal';
                            src: url('/akshab_pos_sales_report/static/fonts/Tajawal-Medium.ttf') format('truetype');
                            font-weight: 500;
                            font-style: normal;
                        }
                        @font-face {
                            font-family: 'Tajawal';
                            src: url('/akshab_pos_sales_report/static/fonts/Tajawal-Bold.ttf') format('truetype');
                            font-weight: bold;
                            font-style: normal;
                        }
                        .akshab-report {
                            direction: rtl;
                            text-align: right;
                            font-family: 'Tajawal', 'Noto Naskh Arabic', 'DejaVu Sans', sans-serif;
                            color: #26312B;
                            font-size: 15px;
                        }
                        .akshab-report table { direction: rtl; }
                        /* ---------- الترويسة (divs عائمة - بدون جدول = استحالة ظهور خطوط) ---------- */
                        .ak-header { width: 100%; overflow: hidden; margin-bottom: 16px; }
                        .ak-header-titles { float: right; text-align: right; }
                        .ak-header-logo { float: left; text-align: left; }
                        .ak-logo { max-height: 76px; max-width: 230px; }
                        .ak-title { font-size: 32px; font-weight: bold; color: #1B4332; margin: 0; line-height: 1.25; border: 0 !important; }
                        .ak-subtitle { font-size: 15px; color: #C6A46C; font-weight: bold; margin: 3px 0 0 0; letter-spacing: 3px; border: 0 !important; }
                        /* ---------- مؤشرات الأداء ---------- */
                        .akshab-report .ak-kpi-table { width: 100%; border-collapse: separate; border-spacing: 5px 0; margin: 4px 0 14px 0; border: 0 !important; }
                        .akshab-report .ak-kpi-table td {
                            background-color: #F7F4EE;
                            border: 0 !important;
                            border-top: 3px solid #C6A46C !important;
                            border-bottom: 1px solid #E5DECF !important;
                            padding: 11px 6px 9px 6px;
                            text-align: center;
                            width: 14.28%;
                        }
                        .ak-kpi-value { font-size: 19px; font-weight: bold; color: #1B4332; direction: ltr; unicode-bidi: embed; white-space: nowrap; }
                        .ak-kpi-value-rtl { font-size: 19px; font-weight: bold; color: #1B4332; direction: rtl; white-space: nowrap; }
                        .ak-kpi-label { font-size: 12.5px; color: #7A6A45; font-weight: 500; margin-top: 3px; }
                        /* ---------- صندوق معلومات الفترة ---------- */
                        .akshab-report .ak-info-box { width: 100%; border-collapse: collapse; margin-bottom: 20px; background-color: #FDFCF9; }
                        .akshab-report .ak-info-box td { padding: 9px 15px; font-size: 14.5px; border: 1px solid #E5DECF !important; }
                        .akshab-report .ak-info-box td.ak-info-label { color: #1B4332; font-weight: bold; white-space: nowrap; width: 1%; background-color: #EFE9DC; }
                        /* ---------- منع انفصال العنوان عن محتواه بين الصفحات ---------- */
                        .ak-keep { page-break-inside: avoid; }
                        .ak-page-start { page-break-before: always; }
                        /* ---------- عناوين الأقسام ---------- */
                        .ak-section-title {
                            background-color: #1B4332; color: #FFFFFF;
                            font-size: 18.5px; font-weight: bold;
                            padding: 10px 17px; margin: 26px 0 0 0;
                            border-right: 6px solid #C6A46C;
                            page-break-after: avoid;
                        }
                        .akshab-report .ak-table caption.ak-section-caption {
                            caption-side: top;
                            background-color: #1B4332; color: #FFFFFF;
                            font-size: 18.5px; font-weight: bold;
                            padding: 10px 17px; text-align: right;
                            border-right: 6px solid #C6A46C;
                            margin: 0;
                        }
                        .ak-table thead tr { page-break-inside: avoid; }
                        .akshab-report .ak-section-table { margin-top: 26px; }
                        .ak-section-num {
                            display: inline-block; color: #C6A46C; font-weight: bold; margin-left: 10px;
                        }
                        /* ---------- الجداول ---------- */
                        .akshab-report .ak-table { width: 100%; border-collapse: collapse; margin-top: 0; }
                        .akshab-report .ak-table th {
                            background-color: #1B4332; color: #FFFFFF;
                            padding: 10px 8px; font-size: 15px; font-weight: bold;
                            border: 1px solid #143226 !important; text-align: center;
                        }
                        .akshab-report .ak-table td {
                            padding: 8px 8px; font-size: 14.5px;
                            border: 1px solid #DDD6C7 !important; text-align: center;
                        }
                        .akshab-report .ak-table td.ak-right { text-align: right; }
                        .akshab-report .ak-table tr:nth-child(even) td { background-color: #F7F4EE; }
                        .ak-table tr { page-break-inside: avoid; }
                        .ak-table thead { display: table-header-group; page-break-inside: avoid; }
                        .akshab-report .ak-total-row td {
                            background-color: #EAE0CC !important; color: #1B4332;
                            font-weight: bold; font-size: 14.5px;
                            border-top: 2px solid #C6A46C !important;
                        }
                        .akshab-report .ak-subtotal-row td {
                            background-color: #F0E9DA !important; color: #1B4332;
                            font-weight: bold; font-size: 14px;
                        }
                        .akshab-report .ak-cat-row td {
                            background-color: #2D5443 !important; color: #FFFFFF;
                            font-weight: bold; text-align: right; font-size: 14.5px;
                        }
                        .akshab-report .ak-cat-row td.ak-num { text-align: center; }
                        .ak-pos-band {
                            background-color: #C6A46C; color: #1B4332;
                            font-weight: bold; font-size: 16px;
                            padding: 8px 15px; margin: 18px 0 0 0;
                            page-break-after: avoid;
                        }
                        .ak-empty { color: #8A8A8A; font-size: 14px; padding: 12px 6px; font-style: italic; }
                        .ak-amount { direction: ltr; unicode-bidi: embed; white-space: nowrap; }
                        .ak-badge-new { color: #1B4332; font-weight: bold; }
                        .ak-badge-old { color: #7A6A45; font-weight: bold; }
                        /* ---------- إضافات التقرير الأسبوعي ---------- */
                        .akshab-report .ak-best-row td {
                            background-color: #F3E9D2 !important;
                            border-top: 1px solid #C6A46C !important;
                            border-bottom: 1px solid #C6A46C !important;
                            font-weight: bold; color: #1B4332;
                        }
                        .ak-best-badge { color: #C6A46C; font-weight: bold; float: left; direction: rtl; }
                        .ak-up { color: #1B4332; font-weight: bold; }
                        .ak-down { color: #A94438; font-weight: bold; }
                        .ak-flat { color: #7A6A45; font-weight: bold; }
                        .akshab-report .ak-matrix th { font-size: 13px; padding: 8px 3px; }
                        .akshab-report .ak-matrix td { font-size: 13.5px; padding: 8px 3px; }
                        .ak-rank { color: #C6A46C; font-weight: bold; }
                    </style>

                    <div class="akshab-report">
                        <!-- ==================== الترويسة ==================== -->
                        <div class="ak-header">
                            <div class="ak-header-titles">
                                <p class="ak-title">تقرير المبيعات الأسبوعي</p>
                                <p class="ak-subtitle">WEEKLY SALES REPORT</p>
                            </div>
                            <div class="ak-header-logo">
                                <img t-if="company.logo" class="ak-logo"
                                     t-att-src="image_data_uri(company.logo)"/>
                                <p t-else="" class="ak-title" t-out="data.get('company_name')"/>
                            </div>
                        </div>

                        <!-- ==================== مؤشرات الأداء التنفيذية ==================== -->
                        <table t-if="data.get('has_data')" class="ak-kpi-table">
                            <tr>
                                <td>
                                    <div class="ak-kpi-value" t-out="data['kpis']['gross_fmt']"/>
                                    <div class="ak-kpi-label">إجمالي المبيعات (ر.س)</div>
                                </td>
                                <td>
                                    <div class="ak-kpi-value" t-out="data['kpis']['refunds_fmt']"/>
                                    <div class="ak-kpi-label">المرتجعات (ر.س)</div>
                                </td>
                                <td>
                                    <div class="ak-kpi-value" t-out="data['kpis']['net_fmt']"/>
                                    <div class="ak-kpi-label">صافي المبيعات (ر.س)</div>
                                </td>
                                <td>
                                    <div class="ak-kpi-value" t-out="data['kpis']['invoices']"/>
                                    <div class="ak-kpi-label">عدد الفواتير</div>
                                </td>
                                <td>
                                    <div class="ak-kpi-value" t-out="data['kpis']['avg_fmt']"/>
                                    <div class="ak-kpi-label">متوسط الفاتورة (ر.س)</div>
                                </td>
                                <td>
                                    <div class="ak-kpi-value" t-out="data['kpis']['discounts_fmt']"/>
                                    <div class="ak-kpi-label">إجمالي الخصومات (ر.س)</div>
                                </td>
                                <td>
                                    <div class="ak-kpi-value-rtl">&#8207;<t t-out="data['kpis']['customers_display']"/></div>
                                    <div class="ak-kpi-label">عدد العملاء</div>
                                </td>
                            </tr>
                        </table>

                        <table class="ak-info-box">
                            <tr>
                                <td class="ak-info-label">الأسبوع من</td>
                                <td t-out="data.get('week_from')"/>
                                <td class="ak-info-label">إلى</td>
                                <td t-out="data.get('week_to')"/>
                            </tr>
                            <tr>
                                <td class="ak-info-label">الفروع</td>
                                <td colspan="3" t-out="data.get('config_names')"/>
                            </tr>
                            <tr>
                                <td class="ak-info-label">تاريخ الطباعة</td>
                                <td><span class="ak-amount" t-out="data.get('printed_on')"/></td>
                                <td class="ak-info-label">العملة</td>
                                <td>ريال سعودي (<t t-out="data.get('currency')"/>)</td>
                            </tr>
                        </table>

                        <t t-if="not data.get('has_data')">
                            <p class="ak-empty">لا توجد عمليات بيع ضمن الأسبوع والفروع المحددة.</p>
                        </t>

                        <t t-if="data.get('has_data')">
                        <!-- ==================== القسم الأسبوعي 1: المبيعات اليومية ==================== -->
                        <div class="ak-keep">
                        <div class="ak-section-title"><span class="ak-section-num">١</span> المبيعات اليومية خلال الأسبوع</div>
                        <table class="ak-table">
                            <thead>
                                <tr>
                                    <th style="width: 16%;">اليوم</th>
                                    <th style="width: 13%;">التاريخ</th>
                                    <th style="width: 16%;">المبيعات (<t t-out="data['currency']"/>)</th>
                                    <th style="width: 10%;">عدد الفواتير</th>
                                    <th style="width: 14%;">متوسط الفاتورة</th>
                                    <th style="width: 16%;">الخصومات (<t t-out="data['currency']"/>)</th>
                                    <th style="width: 15%;">عدد العملاء</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="data['daily']['rows']" t-as="row"
                                    t-att-class="'ak-best-row' if row['is_best'] else None">
                                    <td class="ak-right">
                                        <span t-if="row['is_best']" class="ak-best-badge">◆ الأفضل</span>
                                        <t t-out="row['day_name']"/>
                                    </td>
                                    <td><span class="ak-amount" t-out="row['date_fmt']"/></td>
                                    <td><span class="ak-amount" t-out="row['total_fmt']"/></td>
                                    <td t-out="row['count']"/>
                                    <td><span class="ak-amount" t-out="row['avg_fmt']"/></td>
                                    <td><span class="ak-amount" t-out="row['discounts_fmt']"/></td>
                                    <td t-out="row['customers']"/>
                                </tr>
                                <tr class="ak-total-row">
                                    <td class="ak-right" colspan="2">إجمالي الأسبوع</td>
                                    <td><span class="ak-amount" t-out="data['daily']['total']['total_fmt']"/></td>
                                    <td t-out="data['daily']['total']['count']"/>
                                    <td><span class="ak-amount" t-out="data['daily']['total']['avg_fmt']"/></td>
                                    <td><span class="ak-amount" t-out="data['daily']['total']['discounts_fmt']"/></td>
                                    <td t-out="data['daily']['total']['customers']"/>
                                </tr>
                            </tbody>
                        </table>
                        </div>

                        <!-- ==================== القسم الأسبوعي 2: مقارنة بالأسبوع السابق ==================== -->
                        <div class="ak-keep">
                        <div class="ak-section-title"><span class="ak-section-num">٢</span> مقارنة بالأسبوع السابق</div>
                        <table class="ak-table">
                            <thead>
                                <tr>
                                    <th style="width: 28%;">المؤشر</th>
                                    <th style="width: 20%;">هذا الأسبوع</th>
                                    <th style="width: 20%;">الأسبوع السابق</th>
                                    <th style="width: 17%;">التغير</th>
                                    <th style="width: 15%;">نسبة التغير</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="data['comparison']['rows']" t-as="row">
                                    <td class="ak-right" t-out="row['label']"/>
                                    <td><span class="ak-amount" t-out="row['current_fmt']"/></td>
                                    <td><span class="ak-amount" t-out="row['previous_fmt']"/></td>
                                    <td><span t-att-class="row['class']"><span class="ak-amount" t-out="row['diff_fmt']"/></span></td>
                                    <td><span t-att-class="row['class']"><span class="ak-amount" t-out="row['pct_fmt']"/></span></td>
                                </tr>
                            </tbody>
                        </table>
                        </div>

                        <!-- ==================== القسم الأسبوعي 3: اتجاه آخر 4 أسابيع ==================== -->
                        <div class="ak-keep">
                        <div class="ak-section-title"><span class="ak-section-num">٣</span> اتجاه آخر 4 أسابيع</div>
                        <table class="ak-table">
                            <thead>
                                <tr>
                                    <th style="width: 24%;">الأسبوع</th>
                                    <th style="width: 14%;">المبيعات (<t t-out="data['currency']"/>)</th>
                                    <th style="width: 10%;">النمو</th>
                                    <th style="width: 10%;">عدد الفواتير</th>
                                    <th style="width: 14%;">متوسط الفاتورة</th>
                                    <th style="width: 10%;">عدد العملاء</th>
                                    <th style="width: 18%;">الخصومات (<t t-out="data['currency']"/>)</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="data['trend']['rows']" t-as="row"
                                    t-att-class="'ak-best-row' if row['is_current'] else None">
                                    <td class="ak-right">
                                        <span t-if="row['is_current']" class="ak-best-badge">◆ الحالي</span>
                                        <t t-out="row['label']"/>
                                    </td>
                                    <td><span class="ak-amount" t-out="row['total_fmt']"/></td>
                                    <td><span t-att-class="row['growth_class']"><span class="ak-amount" t-out="row['growth_fmt']"/></span></td>
                                    <td t-out="row['count']"/>
                                    <td><span class="ak-amount" t-out="row['avg_fmt']"/></td>
                                    <td t-out="row['customers']"/>
                                    <td><span class="ak-amount" t-out="row['discounts_fmt']"/></td>
                                </tr>
                            </tbody>
                        </table>
                        </div>

                        <!-- ==================== القسم الأسبوعي 4: مصفوفة الفروع × الأيام ==================== -->
                        <div class="ak-keep">
                        <div class="ak-section-title"><span class="ak-section-num">٤</span> المبيعات اليومية حسب الفرع (<t t-out="data['currency']"/>)</div>
                        <table class="ak-table ak-matrix">
                            <thead>
                                <tr>
                                    <th style="width: 16%;">الفرع</th>
                                    <t t-foreach="data['matrix']['headers']" t-as="h">
                                        <th style="width: 10.5%;"><t t-out="h['day_name']"/><br/><span class="ak-amount" t-out="h['date_fmt']"/></th>
                                    </t>
                                    <th style="width: 10.5%;">الإجمالي</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="data['matrix']['rows']" t-as="row">
                                    <td class="ak-right" t-out="row['name']"/>
                                    <t t-foreach="row['cells']" t-as="cell">
                                        <td><span class="ak-amount" t-out="cell"/></td>
                                    </t>
                                    <td><span class="ak-amount" t-out="row['total_fmt']"/></td>
                                </tr>
                                <tr class="ak-total-row">
                                    <td class="ak-right">الإجمالي اليومي</td>
                                    <t t-foreach="data['matrix']['day_totals']" t-as="cell">
                                        <td><span class="ak-amount" t-out="cell"/></td>
                                    </t>
                                    <td><span class="ak-amount" t-out="data['matrix']['grand_fmt']"/></td>
                                </tr>
                            </tbody>
                        </table>
                        </div>

                        <!-- ==================== القسم الأسبوعي 4: إجمالي المبيعات حسب الفرع ==================== -->
                        <div class="ak-keep">
                        <div class="ak-section-title"><span class="ak-section-num">٥</span> إجمالي المبيعات حسب الفرع</div>
                        <table class="ak-table">
                            <thead>
                                <tr>
                                    <th style="width: 17%;">الفرع</th>
                                    <th style="width: 13%;">إجمالي المبيعات (<t t-out="data['currency']"/>)</th>
                                    <th style="width: 8%;">النسبة</th>
                                    <th style="width: 10%;">عدد الفواتير</th>
                                    <th style="width: 11%;">متوسط الفاتورة</th>
                                    <th style="width: 13%;">إجمالي الخصومات (<t t-out="data['currency']"/>)</th>
                                    <th style="width: 10%;">عدد العملاء</th>
                                    <th style="width: 9%;">عملاء جدد</th>
                                    <th style="width: 9%;">عملاء قدامى</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="data['section1']['rows']" t-as="row">
                                    <td class="ak-right" t-out="row['name']"/>
                                    <td><span class="ak-amount" t-out="row['total_fmt']"/></td>
                                    <td><span class="ak-amount" t-out="row['share_fmt']"/></td>
                                    <td t-out="row['count']"/>
                                    <td><span class="ak-amount" t-out="row['avg_fmt']"/></td>
                                    <td><span class="ak-amount" t-out="row['discounts_fmt']"/></td>
                                    <td t-out="row['customers']"/>
                                    <td class="ak-badge-new" t-out="row['new']"/>
                                    <td class="ak-badge-old" t-out="row['old']"/>
                                </tr>
                                <tr class="ak-total-row">
                                    <td class="ak-right">الإجمالي</td>
                                    <td><span class="ak-amount" t-out="data['section1']['total']['total_fmt']"/></td>
                                    <td><span class="ak-amount" t-out="data['section1']['total']['share_fmt']"/></td>
                                    <td t-out="data['section1']['total']['count']"/>
                                    <td><span class="ak-amount" t-out="data['section1']['total']['avg_fmt']"/></td>
                                    <td><span class="ak-amount" t-out="data['section1']['total']['discounts_fmt']"/></td>
                                    <td t-out="data['section1']['total']['customers']"/>
                                    <td t-out="data['section1']['total']['new']"/>
                                    <td t-out="data['section1']['total']['old']"/>
                                </tr>
                            </tbody>
                        </table>
                        </div>

                        <!-- ==================== القسم الأسبوعي 5: أعلى 10 فواتير ==================== -->
                        <t t-if="not data['top_invoices']['rows']">
                            <div class="ak-keep">
                                <div class="ak-section-title"><span class="ak-section-num">٦</span> أعلى 10 فواتير في الأسبوع</div>
                                <p class="ak-empty">لا توجد فواتير مبيعات ضمن الأسبوع المحدد.</p>
                            </div>
                        </t>
                        <div t-if="data['top_invoices']['rows']" class="ak-keep">
                        <table class="ak-table ak-section-table">
                            <caption class="ak-section-caption"><span class="ak-section-num">٦</span> أعلى 10 فواتير في الأسبوع</caption>
                            <thead>
                                <tr>
                                    <th style="width: 11%;">التاريخ</th>
                                    <th style="width: 12%;">رقم الفاتورة</th>
                                    <th style="width: 10%;">الفرع</th>
                                    <th style="width: 13%;">العميل</th>
                                    <th style="width: 11%;">رقم الهاتف</th>
                                    <th style="width: 8%;">عميل جديد؟</th>
                                    <th style="width: 11%;">تاريخ آخر فاتورة</th>
                                    <th style="width: 10%;">الأيام منذ آخر فاتورة</th>
                                    <th style="width: 14%;">الإجمالي (<t t-out="data['currency']"/>)</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="data['top_invoices']['rows']" t-as="row">
                                    <td><span class="ak-amount" t-out="row['date']"/></td>
                                    <td><span class="ak-amount" t-out="row['number']"/></td>
                                    <td t-out="row['pos']"/>
                                    <td t-out="row['customer']"/>
                                    <td><span class="ak-amount" t-out="row['phone']"/></td>
                                    <td t-out="row['is_new']"/>
                                    <td><span class="ak-amount" t-out="row['last_inv']"/></td>
                                    <td t-out="row['days']"/>
                                    <td><span class="ak-amount" t-out="row['total_fmt']"/></td>
                                </tr>
                                <tr class="ak-total-row">
                                    <td class="ak-right" colspan="2">إجمالي الأسبوع</td>
                                    <td colspan="6">إجمالي فواتير الأسبوع: <t t-out="data['top_invoices']['count']"/></td>
                                    <td><span class="ak-amount" t-out="data['top_invoices']['total_fmt']"/></td>
                                </tr>
                            </tbody>
                        </table>
                        </div>

                        <!-- ==================== القسم الأسبوعي 6: مرتجعات المبيعات ==================== -->
                        <t t-if="not data['section3']['rows']">
                            <div class="ak-keep">
